{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://myworldheritage.example/schema/usage-summary.json",
  "title": "My World Heritage usage summary",
  "type": "object",
  "required": [
    "date",
    "magic_cookie",
    "use_count_since_last_push",
    "total_site_count"
  ],
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "magic_cookie": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{16,64}$"
    },
    "use_count_since_last_push": {
      "type": "integer",
      "minimum": 0
    },
    "total_site_count": {
      "type": "integer",
      "minimum": 0
    },
    "source": {
      "type": "string",
      "maxLength": 80
    },
    "user_agent": {
      "type": "string",
      "maxLength": 512
    },
    "token": {
      "type": "string",
      "minLength": 8,
      "maxLength": 256
    }
  },
  "additionalProperties": false
}
