{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://myworldheritage.example/schema/usage-summary.json",
  "title": "My World Heritage usage summary",
  "type": "object",
  "required": [
    "submitted_at_utc",
    "magic_cookie",
    "use_count_since_last_push",
    "visited_site_count"
  ],
  "properties": {
    "submitted_at_utc": {
      "type": "string",
      "format": "date-time",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}T.*Z$"
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "deprecated": true
    },
    "magic_cookie": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{16,64}$"
    },
    "use_count_since_last_push": {
      "type": "integer",
      "minimum": 0
    },
    "visited_site_count": {
      "type": "integer",
      "minimum": 0
    },
    "event_type": {
      "type": "string",
      "enum": [
        "periodic",
        "manual",
        "adoption"
      ]
    },
    "total_site_count": {
      "type": "integer",
      "minimum": 0,
      "deprecated": true
    },
    "source": {
      "type": "string",
      "maxLength": 80
    },
    "user_agent": {
      "type": "string",
      "maxLength": 512
    },
    "token": {
      "type": "string",
      "minLength": 8,
      "maxLength": 256
    }
  },
  "additionalProperties": false
}
